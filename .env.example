# Supabase (project txozgrstheetzxeglicu, eu-west-1)
NEXT_PUBLIC_SUPABASE_URL=https://txozgrstheetzxeglicu.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key>
# Vul in vanuit Supabase dashboard > Settings > API (nooit committen):
SUPABASE_SERVICE_ROLE_KEY=

# Escrow: live verwerking van cliëntgevoelige data staat UIT (veiligheidsklep)
ESCROW_LIVE_PROCESSING=false

# Basis-URL van dit platform (voor attestaties en agent.json)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Ed25519 ondertekening (dev-sleutelpaar; roteren voor productie)
BNA_SIGNING_PRIVATE_KEY="<pkcs8 pem, \n-escaped>"
BNA_SIGNING_PUBLIC_KEY="<spki pem, \n-escaped>"
